# Запрет доступа к директории admin
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Разрешение доступа только к определенным файлам
<FilesMatch "^(index|login|logout|main|articles|news|products|categories|faq|content|settings|menu|contacts|admins|logs|profile)\.php$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Allow from all
    </IfModule>
</FilesMatch>

# Запрет доступа к файлам .htaccess и .env
<FilesMatch "^(\.htaccess|\.env)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Настройки PHP
php_value upload_max_filesize 10M
php_value post_max_size 12M
php_value max_execution_time 300
php_value max_input_time 300

# Включение отладки (убрать в продакшене)
php_flag display_errors on
php_value error_reporting E_ALL