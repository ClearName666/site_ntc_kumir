    "border-section": "2px solid var(--contacts-light)",
    "border-purple": "2px solid var(--contacts-primary)",
    "radius-sm": "6px",
    "radius-md": "8px",
    "radius-card": "12px",
    "radius-lg": "16px",
    "radius-badge": "20px",
    "radius-btn": "50px",
    "transition-smooth": "all 0.3s ease",
    "transition-card": "all 0.3s ease"
}