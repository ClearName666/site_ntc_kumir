{
    "primary-blue": "#3498db",
    "dark-blue": "#2980b9",
    "text-dark": "#2c3e50",
    "text-light": "#7f8c8d",
    "text-gray": "#666",
    "text-meta": "#95a5a6",
    "bg-light": "#f8f9fa",
    "bg-white-transparent": "rgba(255, 255, 255, 0.3)",
    "bg-overlay": "rgba(255, 255, 255, 0.4)",
    "shadow-sm": "0 5px 20px rgba(0, 0, 0, 0.08)",
    "shadow-md": "0 10px 40px rgba(0, 0, 0, 0.1)",
